NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alleen server-side: nodig voor openbare planning-URL (/api/planning/public-view). Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Publieke basis-URL (links in mail + logo). Op Vercel: zet je eigen domein, bv. https://planning.jouwdomein.nl
# Als dit leeg is, gebruikt de app op Vercel automatisch VERCEL_URL (meestal *.vercel.app).
PUBLIC_APP_BASE_URL=
# Geheime sleutel voor niet-manipuleerbare persoonlijke links
PUBLIC_LINK_SIGNING_SECRET=

# SMTP (mail uitsturen bij publiceren)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# Optioneel: waar "Beantwoorden" naartoe gaat (als leeg: zelfde als MAIL_FROM)
# MAIL_REPLY_TO=planning@spl-planning.nl
