NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alleen server-side: nodig voor openbare planning-URL (/api/planning/public-view). Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Publieke basis-URL (links in mail + logo). Op Vercel: zet je eigen domein, bv. https://planning.jouwdomein.nl
# Als dit leeg is, gebruikt de app op Vercel automatisch VERCEL_URL (meestal *.vercel.app).
PUBLIC_APP_BASE_URL=
# Geheime sleutel voor niet-manipuleerbare persoonlijke links
PUBLIC_LINK_SIGNING_SECRET=

# Resend (aanbevolen): als RESEND_API_KEY gezet is, worden SMTP_* niet gebruikt.
# Maak een API key op https://resend.com/api-keys en verifieer je domein onder Domains.
RESEND_API_KEY=

# SMTP (alleen als RESEND_API_KEY leeg is — bijv. Gmail of eigen server)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Weergavenaam + adres (RFC 5322). Elke domeinnaam mag, zolang SMTP/DNS dat domein mag versturen:
# MAIL_FROM="SPL opvang <hr@splopvang.nl>"
# MAIL_FROM="SPL Planning <planning@spl-planning.nl>"
MAIL_FROM=
# Waar "Beantwoorden" naartoe gaat, optioneel:
# MAIL_REPLY_TO=hr@splopvang.nl
# MAIL_REPLY_TO=planning@spl-planning.nl
